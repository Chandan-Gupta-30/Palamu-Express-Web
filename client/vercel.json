{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.palamuexpress.com"
        }
      ],
      "destination": "https://palamuexpress.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "palamuexpress.in"
        }
      ],
      "destination": "https://palamuexpress.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
