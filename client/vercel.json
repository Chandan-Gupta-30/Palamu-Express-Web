        {
          "type": "host",
          "value": "www.palamuexpress.in"
        }
      ],
      "destination": "https://palamuexpress.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "palamuexpress.live"
        }
      ],
      "destination": "https://palamuexpress.com/$1",
      "permanent": true
    },
    {
